ARG CUDA_VERSION=12.6.3
ARG UBUNTU_VERSION=24.04
ARG PYTHON_VERSION=3.12
ARG SKIP_OPENAGENT=false

FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu${UBUNTU_VERSION}

ARG MYUID=1000
ARG MYGID=1000
ARG DOCKER_USERNAME=hannya

ENV DEBIAN_FRONTEND=noninteractive

# ── System ────────────────────────────────────────────────────────────────────
RUN --mount=type=cache,sharing=locked,target=/var/cache/apt \
    --mount=type=cache,sharing=locked,target=/var/lib/apt \
    apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates nano wget git bash-completion unzip sudo build-essential

# ── Node.js 22 ────────────────────────────────────────────────────────────────
RUN curl -fsSL https://nodejs.org/dist/v22.22.2/node-v22.22.2-linux-x64.tar.gz | tar -xz -C /usr/local --strip-components=1

# ── uv ────────────────────────────────────────────────────────────────────────
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
ENV PATH="/root/.local/bin:${PATH}"
RUN uv python install ${PYTHON_VERSION} && \
    echo "${PYTHON_VERSION}" > /root/.python-version

# ── User ──────────────────────────────────────────────────────────────────────
RUN OLD_USER=$(awk -v uid="${MYUID}" -F ':' '$3==uid {print $1}' /etc/passwd) && \
    if [ -z "${OLD_USER}" ]; then \
    EXISTING_GRP=$(getent group ${MYGID} | cut -d: -f1) && \
    if [ -z "$EXISTING_GRP" ]; then \
    groupadd -g ${MYGID} ${DOCKER_USERNAME} && \
    useradd -m -u ${MYUID} -g ${MYGID} -s /bin/bash ${DOCKER_USERNAME}; \
    else \
    useradd -m -u ${MYUID} -g "$EXISTING_GRP" -s /bin/bash ${DOCKER_USERNAME}; \
    fi; \
    else \
    usermod -l ${DOCKER_USERNAME} "${OLD_USER}" && \
    usermod -d /home/${DOCKER_USERNAME} -m ${DOCKER_USERNAME}; \
    fi && \
    mkdir -p /etc/sudoers.d && \
    echo "${DOCKER_USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/${DOCKER_USERNAME} && \
    chmod 0440 /etc/sudoers.d/${DOCKER_USERNAME} && \
    touch /home/${DOCKER_USERNAME}/.sudo_as_admin_successful && \
    echo 'export PS1="\[\e[01;36m\][DOCKER]\[\e[00m\] \u@\h:\w\$ "' >> /home/${DOCKER_USERNAME}/.bashrc

# ── NVIDIA ────────────────────────────────────────────────────────────────────
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics
ENV LD_LIBRARY_PATH=/usr/local/nvidia/lib:/usr/local/nvidia/lib64:${LD_LIBRARY_PATH}

# ── Project configs ───────────────────────────────────────────────────────────
COPY --chown=${DOCKER_USERNAME}:${MYGID} configs/opencode/ /home/${DOCKER_USERNAME}/.config/opencode/
COPY --chown=${DOCKER_USERNAME}:${MYGID} configs/opencode/AGENTS.md-global /home/${DOCKER_USERNAME}/.config/opencode/AGENTS.md
COPY --chown=${DOCKER_USERNAME}:${MYGID} configs/opencode/switch-opencode-config.sh /usr/local/bin/switch-opencode-config
RUN chmod +x /usr/local/bin/switch-opencode-config

# ── Everything else as user ──────────────────────────────────────────────────
USER ${DOCKER_USERNAME}
ENV HOME=/home/${DOCKER_USERNAME}
ENV PATH="/home/${DOCKER_USERNAME}/.opencode/bin:/home/${DOCKER_USERNAME}/.local/bin:/home/${DOCKER_USERNAME}/.bun/bin:${PATH}"

# Bun
RUN curl -fsSL https://bun.sh/install | bash

# OpenCode
RUN curl -fsSL https://opencode.ai/install | bash

# oh-my-openagent (--build-arg SKIP_OPENAGENT=true)
RUN if [ "${SKIP_OPENAGENT}" != "true" ]; then \
    bunx oh-my-openagent install --no-tui --claude=no --openai=no --gemini=no --copilot=no --opencode-zen=yes && \
    cp ~/.config/opencode/oh-my-openagent.json ~/.config/opencode/oh-my-openagent-default.json; \
    fi

# ── Entrypoint ────────────────────────────────────────────────────────────────
COPY --chown=${DOCKER_USERNAME}:${MYGID} entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV TERM=xterm-256color
ENV SHELL=/bin/bash

WORKDIR /workspace

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
