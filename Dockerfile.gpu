# ==============================================================================
# Generic AI Dev Container — GPU (CUDA 12)
# ==============================================================================
# Usage: mount any project, run `uv sync`, launch `opencode`
# ==============================================================================

ARG CUDA_VERSION=12.6.3
ARG UBUNTU_VERSION=24.04

FROM nvidia/cuda:${CUDA_VERSION}-runtime-ubuntu${UBUNTU_VERSION}

ARG MYUID=1000
ARG MYGID=1000
ARG USERNAME=hannya

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/root

# ── System ────────────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    nano git curl wget ca-certificates bash-completion unzip sudo \
    build-essential libgl1 libglib2.0-0 libxrender1 libxext6 \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 20 ────────────────────────────────────────────────────────────────
RUN curl -fsSL https://nodejs.org/dist/v20.18.0/node-v20.18.0-linux-x64.tar.gz | tar -xz -C /usr/local --strip-components=1

# ── uv ────────────────────────────────────────────────────────────────────────
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# ── Bun ───────────────────────────────────────────────────────────────────────
RUN curl -fsSL https://bun.sh/install | bash && \
    cp $HOME/.bun/bin/bun /usr/local/bin/bun && \
    cp $HOME/.bun/bin/bunx /usr/local/bin/bunx

# ── OpenCode + oh-my-openagent ───────────────────────────────────────────────
RUN curl -fsSL https://opencode.ai/install | bash
RUN npm install -g oh-my-opencode oh-my-opencode-linux-x64
RUN bunx oh-my-opencode install --no-tui --claude=no --openai=no --gemini=no --copilot=no --opencode-zen=yes

# Ensure opencode binary is on PATH
RUN cp $HOME/.opencode/bin/opencode /usr/local/bin/opencode

# Save generated config to a safe location (not overwritten by bind mounts)
RUN mkdir -p /opt/opencode-config && \
    cp -r $HOME/.config/opencode/* /opt/opencode-config/ 2>/dev/null || true && \
    cp configs/templates/AGENTS.md-global /opt/opencode-config/AGENTS.md

# ── User ──────────────────────────────────────────────────────────────────────
RUN OLD_USER=$(awk -v uid="${MYUID}" -F ':' '$3==uid {print $1}' /etc/passwd) && \
    if [ -z "${OLD_USER}" ]; then \
        EXISTING_GRP=$(getent group ${MYGID} | cut -d: -f1) && \
        if [ -z "$EXISTING_GRP" ]; then \
            addgroup --gid ${MYGID} ${USERNAME} && \
            adduser --disabled-password --gecos "" --uid ${MYUID} --gid ${MYGID} ${USERNAME}; \
        else \
            adduser --disabled-password --gecos "" --uid ${MYUID} --gid $EXISTING_GRP ${USERNAME}; \
        fi; \
    else \
        usermod -l ${USERNAME} "${OLD_USER}" && \
        usermod -d /home/${USERNAME} -m ${USERNAME}; \
    fi && \
    mkdir -p /etc/sudoers.d && \
    echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/${USERNAME} && \
    chmod 0440 /etc/sudoers.d/${USERNAME} && \
    touch /home/${USERNAME}/.sudo_as_admin_successful

# ── NVIDIA ────────────────────────────────────────────────────────────────────
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics
ENV LD_LIBRARY_PATH=/usr/local/nvidia/lib:/usr/local/nvidia/lib64:${LD_LIBRARY_PATH}

ENV TERM=xterm-256color
ENV SHELL=/bin/bash
ENV HOME=/home/${USERNAME}
ENV PATH="/home/${USERNAME}/.local/bin:/home/${USERNAME}/.bun/bin:${PATH}"

WORKDIR /workspace

# ── Entrypoint: cd to workspace, sync uv if pyproject.toml exists ─────────────
COPY --chown=${USERNAME}:${MYGID} entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER ${USERNAME}

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
