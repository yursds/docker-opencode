PROJECT_NAME=my-project
PROJECT_PATH=/path/to/my-project

###!!! IMPORTANT !!!
#! Build-time flags (pass via --build-arg during docker build):
# User/group IDs — MUST match your host user (run `id` on your host)
# If your UID/GID differs from 1000, replace with your actual values
# with --build-arg MYUID=... --build-arg MYGID=... or in .env
# Set CUDA_VERSION, UBUNTU_VERSION, PYTHON_VERSION in .env or with --build-arg
# Set SKIP_OPENAGENT=true to skip oh-my-openagent installation in .env or with --build-arg

OPENCODE_CONFIG=free

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
