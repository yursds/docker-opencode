PROJECT_NAME=my-project
PROJECT_PATH=/path/to/my-project

# User/group IDs — MUST match your host user (run `id` on your host)
# If your UID/GID differs from 1000, replace with your actual values
MYUID=1000
MYGID=1000

# Container user name (default: hannya)
DOCKER_USERNAME=hannya

# Container hostname (default: naraku)
HOSTNAME=naraku

# CUDA_VERSION=12.4.1      # CUDA toolkit version (for GPU builds)
# UBUNTU_VERSION=22.04      # Ubuntu version (for specific builds)
# PYTHON_VERSION=3.12      # Python version (default: 3.12)

OPENCODE_CONFIG=free

# Build-time flags (uncomment to skip during docker build):
# SKIP_OPENAGENT=true    # Skip oh-my-openagent installation
# SKIP_GRAPHIFY=true     # Skip graphify skill installation

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
