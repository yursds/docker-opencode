# ==============================================================================
# Benchmarking Dockerfile - Test OpenCode plugin combinations
# ==============================================================================
# Plugins tested:
#   - oh-my-openagent (code-yeongyu/oh-my-openagent)
#   - superpowers (obra/superpowers)
#   - graphify (safishamsi/graphify)
#   - gstack (TMFNK/gstack-OpenCode)
# ==============================================================================

ARG UBUNTU_VERSION=24.04
FROM ubuntu:${UBUNTU_VERSION}

ARG MYUID=1000
ARG MYGID=1000
ARG DOCKER_USERNAME=hannya

ENV DEBIAN_FRONTEND=noninteractive

# ── System ────────────────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    nano git curl wget ca-certificates bash-completion unzip sudo \
    build-essential libgl1 libglib2.0-0 libxrender1 libxext6 \
    python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 22 ────────────────────────────────────────────────────────────
RUN curl -fsSL https://nodejs.org/dist/v22.22.2/node-v22.22.2-linux-x64.tar.gz | tar -xz -C /usr/local --strip-components=1

# ── uv ────────────────────────────────────────────────────────────────────────
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# ── User ────────────────────────────────────────────────────────────────
RUN OLD_USER=$(awk -v uid="${MYUID}" -F ':' '$3==uid {print $1}' /etc/passwd) && \
    if [ -z "${OLD_USER}" ]; then \
    EXISTING_GRP=$(getent group ${MYGID} | cut -d: -f1) && \
    if [ -z "$EXISTING_GRP" ]; then \
    groupadd -g ${MYGID} ${DOCKER_USERNAME} && \
    useradd -m -u ${MYUID} -g ${MYGID} -s /bin/bash ${DOCKER_USERNAME}; \
    else \
    useradd -m -u ${MYUID} -g "$EXISTING_GRP" -s /bin/bash ${DOCKER_USERNAME}; \
    fi; \
    else \
    usermod -l ${DOCKER_USERNAME} "${OLD_USER}" && \
    usermod -d /home/${DOCKER_USERNAME} -m ${DOCKER_USERNAME}; \
    fi && \
    mkdir -p /etc/sudoers.d && \
    echo "${DOCKER_USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/${DOCKER_USERNAME} && \
    chmod 0440 /etc/sudoers.d/${DOCKER_USERNAME} && \
    touch /home/${DOCKER_USERNAME}/.sudo_as_admin_successful && \
    echo 'export PS1="\[\e[01;36m\][BENCH]\[\e[00m\] \u@\h:\w\$ "' >> /home/${DOCKER_USERNAME}/.bashrc

USER ${DOCKER_USERNAME}
ENV HOME=/home/${DOCKER_USERNAME}
ENV PATH="/home/${DOCKER_USERNAME}/.opencode/bin:/home/${DOCKER_USERNAME}/.local/bin:/home/${DOCKER_USERNAME}/.bun/bin:${PATH}"

# ── Bun ─────────────────���───────────────────────────────────────────────
RUN curl -fsSL https://bun.sh/install | bash

# ── OpenCode ────────────────────────────────────────────────────────────────
RUN curl -fsSL https://opencode.ai/install | bash

# ── oh-my-openagent (plugin) ────────────────────────────────────────────────────────
RUN /home/${DOCKER_USERNAME}/.bun/bin/bunx oh-my-openagent@latest install \
    --no-tui \
    --claude=no \
    --openai=no \
    --gemini=no \
    --copilot=no \
    --opencode-zen=yes

# ── superpowers (plugin) ────────────────────────────────────────────────────
RUN mkdir -p /home/${DOCKER_USERNAME}/.config/opencode && \
    echo '{' > /home/${DOCKER_USERNAME}/.config/opencode/opencode.json && \
    echo '  "$schema": "https://opencode.ai/config.json",' >> /home/${DOCKER_USERNAME}/.config/opencode/opencode.json && \
    echo '  "default_agent": "plan",' >> /home/${DOCKER_USERNAME}/.config/opencode/opencode.json && \
    echo '  "plugin": [' >> /home/${DOCKER_USERNAME}/.config/opencode/opencode.json && \
    echo '    "superpowers@git+https://github.com/obra/superpowers.git",' >> /home/${DOCKER_USERNAME}/.config/opencode/opencode.json && \
    echo '    "oh-my-openagent@latest"' >> /home/${DOCKER_USERNAME}/.config/opencode/opencode.json && \
    echo '  ]' >> /home/${DOCKER_USERNAME}/.config/opencode/opencode.json && \
    echo '}' >> /home/${DOCKER_USERNAME}/.config/opencode/opencode.json

# ── Entrypoint ────────────────────────────────────────────────────────────
COPY --chown=${DOCKER_USERNAME}:${MYGID} entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV TERM=xterm-256color
ENV SHELL=/bin/bash

WORKDIR /workspace/benchmarking

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]